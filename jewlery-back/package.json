{
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.12.0",
    "@sparticuz/chromium": "^133.0.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.1.4",
    "express": "^5.2.1",
    "google-trends-api": "^4.9.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.6.0",
    "node-cron": "^4.2.1",
    "puppeteer": "^24.40.0",
    "puppeteer-core": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "prisma": "^5.12.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "dev:clean": "powershell -NoProfile -Command \"$p = Get-NetTCPConnection -LocalPort 3001 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique; if ($p) { $p | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue } }; node src/server.js\"",
    "seed:auth": "node seed-auth.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  }
}
