generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Reseller {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  cpf       String   @unique
  phone     String
  role      String   @default("cliente")
  address   String?
  city      String?
  state     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kits        Kit[]
  cards       Card[]
  settlements KitSettlement[]
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  email     String?
  phone     String?

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProductCategory {
  id        Int       @id @default(autoincrement())
  name      String    @unique

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PlatingType {
  id        Int       @id @default(autoincrement())
  name      String    @unique

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Collection {
  id        Int       @id @default(autoincrement())
  name      String    @unique

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProfitMargin {
  id         Int      @id @default(autoincrement())
  level      Int      @unique
  name       String
  multiplier Decimal  @db.Decimal(5, 2)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id             Int      @id @default(autoincrement())

  // Identificação
  code           String?  @db.VarChar(50)
  sku            String?  @unique
  reference      String?  @db.VarChar(100)
  barcode        String?  @unique

  // Informações básicas
  name           String
  description    String?  @db.Text
  image          String?

  // Relacionamentos
  supplierId     Int?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  categoryId     Int?
  category       ProductCategory? @relation(fields: [categoryId], references: [id])

  platingTypeId  Int?
  platingType    PlatingType? @relation(fields: [platingTypeId], references: [id])

  collectionId   Int?
  collection     Collection? @relation(fields: [collectionId], references: [id])

  // Estoque
  quantity       Int       @default(0)
  weight         Decimal?  @db.Decimal(10, 3)

  // Custos
  unitPrice      Decimal?  @db.Decimal(10, 2)
  totalPrice     Decimal?  @db.Decimal(10, 2)

  platingTotal   Decimal?  @db.Decimal(10, 2)
  piecesTotal    Decimal?  @db.Decimal(10, 2)
  grandTotal     Decimal?  @db.Decimal(10, 2)

  // Tabelas de preço
  priceLevel1    Decimal?  @db.Decimal(10, 2)
  priceLevel2    Decimal?  @db.Decimal(10, 2)
  priceLevel3    Decimal?  @db.Decimal(10, 2)

  adjustedPrice  Decimal?  @db.Decimal(10, 2)

  // Controle
  active         Boolean   @default(true)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trends         Trend[]
  kitItems       KitItem[]
}

model Kit {
  id               Int       @id @default(autoincrement())
  kitNumber        Int       @unique

  nature           String    @default("Venda")
  issueDate        DateTime
  returnDate       DateTime

  resellerId       Int?
  reseller         Reseller? @relation(fields: [resellerId], references: [id])

  clientName       String?
  clientAddress    String?   @db.VarChar(255)
  clientCity       String?   @db.VarChar(120)
  clientCpf        String?   @db.VarChar(20)
  clientPhone      String?   @db.VarChar(30)
  clientEmail      String?   @db.VarChar(120)

  paymentTerms     String?   @db.Text
  paymentType      String    @default("avista")
  observations     String?   @db.Text

  extrasShowcase   Decimal   @default(0) @db.Decimal(10, 2)
  extrasRingHolder Decimal   @default(0) @db.Decimal(10, 2)
  extrasBoxes      Int       @default(0)

  totalQty         Int       @default(0)
  productsSubtotal Decimal   @default(0) @db.Decimal(10, 2)
  extrasTotal      Decimal   @default(0) @db.Decimal(10, 2)
  grandTotal       Decimal   @default(0) @db.Decimal(10, 2)
  commissionRate   Decimal   @default(0) @db.Decimal(5, 4)
  commissionValue  Decimal   @default(0) @db.Decimal(10, 2)
  paymentDiscount  Decimal   @default(0) @db.Decimal(5, 4)
  discountValue    Decimal   @default(0) @db.Decimal(10, 2)
  finalTotal       Decimal   @default(0) @db.Decimal(10, 2)

  status           String    @default("montado")

  items            KitItem[]
  card             Card?
  settlement       KitSettlement?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model KitSettlement {
  id               Int      @id @default(autoincrement())
  kitId            Int      @unique
  kit              Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)

  resellerId       Int?
  reseller         Reseller? @relation(fields: [resellerId], references: [id])

  amountDue        Decimal  @db.Decimal(10, 2)
  soldValue        Decimal  @default(0) @db.Decimal(10, 2)
  lostValue        Decimal  @default(0) @db.Decimal(10, 2)
  returnedValue    Decimal  @default(0) @db.Decimal(10, 2)
  soldCount        Int      @default(0)
  lostCount        Int      @default(0)
  returnedCount    Int      @default(0)
  commissionRate   Decimal  @default(0) @db.Decimal(5, 4)
  commissionAmount Decimal  @default(0) @db.Decimal(10, 2)

  paymentStatus    String   @default("pendente")

  finalizedAt      DateTime @default(now())
  paidAt           DateTime?
  confirmedAt      DateTime?

  events           KitSettlementEvent[]
  payments         KitSettlementPayment[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model KitSettlementPayment {
  id           Int           @id @default(autoincrement())
  settlementId Int
  settlement   KitSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  amount       Decimal       @db.Decimal(10, 2)
  note         String?       @db.Text
  status       String        @default("informado")

  reportedAt   DateTime      @default(now())
  confirmedAt  DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model KitSettlementEvent {
  id           Int           @id @default(autoincrement())
  settlementId Int
  settlement   KitSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  type         String
  note         String?       @db.Text
  actor        String

  createdAt    DateTime      @default(now())
}

model KitItem {
  id          Int      @id @default(autoincrement())
  kitId       Int
  kit         Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)

  productId   Int?
  product     Product? @relation(fields: [productId], references: [id])

  reference   String   @db.VarChar(50)
  description String   @db.VarChar(255)
  category    String   @db.VarChar(80)
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)

  units       KitItemUnit[]

  createdAt   DateTime @default(now())
}

model KitItemUnit {
  id             Int      @id @default(autoincrement())
  kitItemId      Int
  kitItem        KitItem  @relation(fields: [kitItemId], references: [id], onDelete: Cascade)

  unitIndex      Int      @default(1)
  unitPrice      Decimal  @db.Decimal(10, 2)

  soldByOwner    Boolean  @default(false)
  soldByReseller Boolean  @default(false)
  missingOrLost  Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([kitItemId, unitIndex])
}

model CommissionTier {
  id         Int      @id @default(autoincrement())
  label      String   @db.VarChar(120)
  maxAmount  Decimal  @db.Decimal(10, 2)
  rate       Decimal  @db.Decimal(5, 4)
  sortOrder  Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Trend {
  id          Int      @id @default(autoincrement())
  productId   Int
  score       Float
  crescimento Float
  status      String
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Board {
  id        Int     @id @default(autoincrement())
  name      String
  active    Boolean @default(true)
  createdAt DateTime @default(now())

  steps Step[]
  cards Card[]
}

model Step {
  id        Int     @id @default(autoincrement())
  boardId   Int
  name      String
  order     Int
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id])
  cards Card[]
}

model Card {
  id          Int       @id @default(autoincrement())
  stepId      Int
  boardId     Int
  title       String
  description String?  @db.Text
  order       Int
  kitId       Int?      @unique
  resellerId  Int?
  createdAt   DateTime  @default(now())

  step     Step      @relation(fields: [stepId], references: [id])
  board    Board     @relation(fields: [boardId], references: [id])
  kit      Kit?      @relation(fields: [kitId], references: [id])
  reseller Reseller? @relation(fields: [resellerId], references: [id])
}

