generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Reseller {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  cpf       String   @unique
  phone     String
  role      String   @default("cliente")
  address   String?
  city      String?
  state     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?  @db.Text
  categoria   String
  imagem      String?
  preco       Float?
  createdAt   DateTime @default(now())

  trends      Trend[]
}

model Trend {
  id          Int      @id @default(autoincrement())
  productId   Int
  score       Float
  crescimento Float
  status      String
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Board {
  id        Int     @id @default(autoincrement())
  name      String
  active    Boolean @default(true)
  createdAt DateTime @default(now())

  steps Step[]
  cards Card[]
}

model Step {
  id        Int     @id @default(autoincrement())
  boardId   Int
  name      String
  order     Int
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id])
  cards Card[]
}

model Card {
  id          Int       @id @default(autoincrement())
  stepId      Int
  boardId     Int
  title       String
  description String?  @db.Text
  order       Int
  createdAt   DateTime  @default(now())

  step Step @relation(fields: [stepId], references: [id])
  board Board @relation(fields: [boardId], references: [id])
}

