generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Reseller {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  cpf       String   @unique
  phone     String
  role      String   @default("cliente")
  address   String?
  city      String?
  state     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  email     String?
  phone     String?

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProductCategory {
  id        Int       @id @default(autoincrement())
  name      String    @unique

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PlatingType {
  id        Int       @id @default(autoincrement())
  name      String    @unique

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Collection {
  id        Int       @id @default(autoincrement())
  name      String    @unique

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id             Int      @id @default(autoincrement())

  // Identificação
  code           String?  @db.VarChar(50)
  sku            String?  @unique
  reference      String?  @db.VarChar(100)
  barcode        String?  @unique

  // Informações básicas
  name           String
  description    String?  @db.Text
  image          String?

  // Relacionamentos
  supplierId     Int?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  categoryId     Int?
  category       ProductCategory? @relation(fields: [categoryId], references: [id])

  platingTypeId  Int?
  platingType    PlatingType? @relation(fields: [platingTypeId], references: [id])

  collectionId   Int?
  collection     Collection? @relation(fields: [collectionId], references: [id])

  // Estoque
  quantity       Int       @default(0)
  weight         Decimal?  @db.Decimal(10, 3)

  // Custos
  unitPrice      Decimal?  @db.Decimal(10, 2)
  totalPrice     Decimal?  @db.Decimal(10, 2)

  platingTotal   Decimal?  @db.Decimal(10, 2)
  piecesTotal    Decimal?  @db.Decimal(10, 2)
  grandTotal     Decimal?  @db.Decimal(10, 2)

  // Tabelas de preço
  priceLevel1    Decimal?  @db.Decimal(10, 2)
  priceLevel2    Decimal?  @db.Decimal(10, 2)
  priceLevel3    Decimal?  @db.Decimal(10, 2)

  adjustedPrice  Decimal?  @db.Decimal(10, 2)

  // Controle
  active         Boolean   @default(true)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trends         Trend[]
}

model Trend {
  id          Int      @id @default(autoincrement())
  productId   Int
  score       Float
  crescimento Float
  status      String
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Board {
  id        Int     @id @default(autoincrement())
  name      String
  active    Boolean @default(true)
  createdAt DateTime @default(now())

  steps Step[]
  cards Card[]
}

model Step {
  id        Int     @id @default(autoincrement())
  boardId   Int
  name      String
  order     Int
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id])
  cards Card[]
}

model Card {
  id          Int       @id @default(autoincrement())
  stepId      Int
  boardId     Int
  title       String
  description String?  @db.Text
  order       Int
  createdAt   DateTime  @default(now())

  step Step @relation(fields: [stepId], references: [id])
  board Board @relation(fields: [boardId], references: [id])
}

